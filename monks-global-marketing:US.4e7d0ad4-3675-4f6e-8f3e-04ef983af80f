    geo.region as geo_region,
    geo.city as geo_city,
    geo.continent as geo_continent,
    geo.sub_continent as geo_sub_continent,

    platform,
    is_active_user

  from `ga-cross-profile-settings.analytics_278291134.events_*`
)

select
  date,
  event_name,
  user_pseudo_id,
  user_id,
  event_ts,

  ga_session_id as session_id,
  ga_session_number,
  concat(
    user_pseudo_id,
    '_',
    coalesce(
      cast(ga_session_id as string),
      cast(timestamp_trunc(event_ts, hour) as string)
    )
  ) as session_key,
  case when ga_session_id is not null then true else false end as has_session_id,
  case when event_name = 'session_start' then true else false end as is_session_start,
  case when event_name = 'first_visit' then true else false end as is_first_visit,
